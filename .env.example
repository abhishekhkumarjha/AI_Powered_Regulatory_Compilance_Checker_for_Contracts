PORT=4000
BACKEND_PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
# FRONTEND_ORIGINS=https://your-frontend.example.com,https://www.your-frontend.example.com

# Leave empty for local development and when the frontend is served by this same backend.
# Vite will proxy /api requests to BACKEND_PORT automatically.
VITE_API_URL=

# Optional blockchain configuration
VITE_CHAIN_ID=11155111
VITE_NETWORK_NAME=Sepolia
VITE_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
VITE_EXPLORER_URL=https://sepolia.etherscan.io
VITE_CONTRACT_ADDRESS=

# Optional AI / Python configuration
GEMINI_API_KEY=
PYTHON_EXECUTABLE=python
